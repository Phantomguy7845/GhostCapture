<Window x:Class="GhostCapture.App.Views.PairingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wi-Fi Debugging Pairing"
        Width="760"
        Height="720"
        MinWidth="740"
        MinHeight="690"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PairRoot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.28" />
                    <DoubleAnimation Storyboard.TargetName="PairRootShift"
                                     Storyboard.TargetProperty="Y"
                                     From="18"
                                     To="0"
                                     Duration="0:0:0.34">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="24">
        <Ellipse Width="200"
                 Height="200"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-90,-40,0"
                 Fill="#45E5CDB1"
                 IsHitTestVisible="False" />

        <Border x:Name="PairRoot"
                Opacity="0"
                Padding="24"
                CornerRadius="28"
                Background="#DBFFF8F1"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PairRootShift" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Wi-Fi Pairing"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Open Wireless debugging and scan this QR."
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="26"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Android: Pair device with QR code"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,22,0,22"
                        Padding="24"
                        CornerRadius="30"
                        Background="#F5E7D8"
                        BorderBrush="#DCC3AE"
                        BorderThickness="1">
                    <Grid>
                        <Border Width="380"
                                Height="380"
                                Padding="22"
                                Background="White"
                                CornerRadius="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Image Source="{Binding QrCodeImage}"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="16"
                        CornerRadius="20"
                        Background="#FFF8F2"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Text="If scan fails, generate a fresh QR and try again."
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <Button Grid.Column="1"
                            Margin="16,0,0,0"
                            Click="CopyPayload_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Copy" />

                    <Button Grid.Column="2"
                            Margin="12,0,0,0"
                            Click="Retry_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Regenerate" />

                    <Button Grid.Column="3"
                            Margin="12,0,0,0"
                            Click="Close_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Close" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
