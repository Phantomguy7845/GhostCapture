<Window x:Class="GhostCapture.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GhostCapture"
        Width="860"
        Height="580"
        MinWidth="840"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <Storyboard x:Key="OpenWifiMorphScene">
            <DoubleAnimation Storyboard.TargetName="HeaderCard"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="HeaderCardShift"
                             Storyboard.TargetProperty="Y"
                             To="-12"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="StartCard"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="StartCardShift"
                             Storyboard.TargetProperty="X"
                             To="-64"
                             Duration="0:0:0.24">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="WifiLauncherCard"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="WifiLauncherShift"
                             Storyboard.TargetProperty="X"
                             To="-42"
                             Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="ModeCard"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ModeCardShift"
                             Storyboard.TargetProperty="X"
                             To="52"
                             Duration="0:0:0.24">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CloseWifiMorphScene">
            <DoubleAnimation Storyboard.TargetName="HeaderCard"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="HeaderCardShift"
                             Storyboard.TargetProperty="Y"
                             To="0"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="StartCard"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="StartCardShift"
                             Storyboard.TargetProperty="X"
                             To="0"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="WifiLauncherCard"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="WifiLauncherShift"
                             Storyboard.TargetProperty="X"
                             To="0"
                             Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="ModeCard"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ModeCardShift"
                             Storyboard.TargetProperty="X"
                             To="0"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HeaderCard"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.28" />
                    <DoubleAnimation Storyboard.TargetName="HeaderCardShift"
                                     Storyboard.TargetProperty="Y"
                                     From="18"
                                     To="0"
                                     Duration="0:0:0.32">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation Storyboard.TargetName="StartCard"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     BeginTime="0:0:0.06"
                                     Duration="0:0:0.32" />
                    <DoubleAnimation Storyboard.TargetName="StartCardShift"
                                     Storyboard.TargetProperty="Y"
                                     From="22"
                                     To="0"
                                     BeginTime="0:0:0.06"
                                     Duration="0:0:0.36">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation Storyboard.TargetName="SideColumn"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     BeginTime="0:0:0.12"
                                     Duration="0:0:0.34" />
                    <DoubleAnimation Storyboard.TargetName="SideColumnShift"
                                     Storyboard.TargetProperty="Y"
                                     From="22"
                                     To="0"
                                     BeginTime="0:0:0.12"
                                     Duration="0:0:0.38">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootSurface" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Ellipse Width="210"
                     Height="210"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-105,-55,0"
                     Fill="#50E7D2BE"
                     IsHitTestVisible="False" />
            <Ellipse Width="150"
                     Height="150"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-30,0,0,-10"
                     Fill="#45E5CFB8"
                     IsHitTestVisible="False" />

            <Border x:Name="HeaderCard"
                    Opacity="0"
                    Padding="20"
                    CornerRadius="24"
                    Background="#D6FFF8F1"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="HeaderCardShift" />
                </Border.RenderTransform>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel MaxWidth="500">
                        <TextBlock Text="GhostCapture"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Quiet Android mirroring, ready in one click"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="24"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Minimal controls. Fast start. Clear status."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            MinWidth="152"
                            Height="44"
                            VerticalAlignment="Center"
                            Click="RefreshConnection_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="{Binding StatusButtonLabel}" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="StartCard"
                    Opacity="0"
                    Padding="26"
                    CornerRadius="30"
                    Background="#E7FFF8F0"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="StartCardShift" />
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                                Padding="12,6"
                                CornerRadius="18"
                                Background="{StaticResource AccentSoftBrush}">
                            <TextBlock Text="Start"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </Border>

                        <TextBlock Margin="0,18,0,0"
                                   Text="Open your phone screen instantly."
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="32"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,12,0,0"
                                   Text="Use USB for the tightest response. Use Wi‑Fi when you want a cleaner desk."
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Padding="18"
                            CornerRadius="24"
                            Background="#F8ECDD"
                            BorderBrush="#E1CCB9"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Connection"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding ConnectionHeadline}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="24"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ConnectionDetail}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2"
                                VerticalAlignment="Bottom"
                                Margin="0,20,0,0">
                        <Button Width="300"
                                Height="92"
                                HorizontalAlignment="Left"
                                Command="{Binding StartScreenCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="{Binding StartButtonLabel}" />
                        <TextBlock Margin="0,14,0,0"
                                   Text="Ready device found, then start."
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="SideColumn"
                  Grid.Column="2"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="SideColumnShift" />
                </Grid.RenderTransform>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="WifiLauncherCard"
                        Padding="20"
                        CornerRadius="26"
                        Background="#FDF8F2"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        MouseLeftButtonUp="OpenWifiPairing_Click">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="WifiLauncherShift" />
                    </Border.RenderTransform>

                    <StackPanel>
                        <TextBlock Text="Wi‑Fi"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Pair with QR code"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="21" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Same network. Scan once. Connect."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button Margin="0,20,0,0"
                                Height="46"
                                Click="OpenWifiPairing_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Connect via Wi‑Fi" />
                    </StackPanel>
                </Border>

                <Border x:Name="ModeCard"
                        Grid.Row="2"
                        Padding="20"
                        CornerRadius="24"
                        Background="#FFF8F0"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ModeCardShift" />
                    </Border.RenderTransform>

                    <StackPanel>
                        <TextBlock Text="Mode"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="USB first"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Keep Wi‑Fi as the quick alternative."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="WifiMorphLayer"
              Panel.ZIndex="10"
              Visibility="Collapsed"
              IsHitTestVisible="False"
              Background="#F3EBDD">
            <Canvas x:Name="WifiMorphCanvas">
                <Border x:Name="WifiMorphCard"
                        Visibility="Collapsed"
                        Width="240"
                        Height="190"
                        Padding="18"
                        CornerRadius="26"
                        Background="#FFF9F3"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <StackPanel x:Name="WifiMorphCompactContent"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Wi‑Fi"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Pair with QR code"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="20"
                                       HorizontalAlignment="Center" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Same network. Scan once. Connect."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <Grid x:Name="WifiMorphExpandedContent" Opacity="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Wi‑Fi Pairing"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Scan this QR."
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="17"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Margin="0,8,0,6">
                                <Border Width="304"
                                        Height="304"
                                        Padding="24"
                                        Background="White"
                                        BorderBrush="#E2D4C6"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Image Source="{Binding QrCodeImage}"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True"
                                           UseLayoutRounding="True" />
                                </Border>
                            </Grid>

                            <TextBlock Grid.Row="2"
                                       Margin="6,0,6,0"
                                       Text="{Binding StatusMessage}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />

                            <StackPanel Grid.Row="3"
                                        Margin="0,10,0,0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Click="CopyWifiPayload_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Copy"
                                        FontSize="13"
                                        Padding="14,8" />

                                <Button Margin="8,0,0,0"
                                        Click="RegenerateWifiPairing_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="New QR"
                                        FontSize="13"
                                        Padding="14,8" />

                                <Button Margin="8,0,0,0"
                                        Click="CloseWifiOverlay_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Close"
                                        FontSize="13"
                                        Padding="16,8" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Canvas>
        </Grid>
    </Grid>
</Window>
